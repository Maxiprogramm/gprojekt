-- Visa alla bokningar med kundnamn och tjänstens namn
SELECT 
    b.BokningID,
    k.Namn AS Kundnamn,
    t.Namn AS Tjanst,
    t.Pris,
    b.Datum
FROM Bokningar b
JOIN Kunder k ON b.KundID = k.KundID
JOIN Tjanster t ON b.TjanstID = t.TjanstID;

-- Hur många bokningar har varje tjänst?
SELECT 
    t.Namn AS Tjanst,
    COUNT(b.BokningID) AS AntalBokningar
FROM Tjanster t
LEFT JOIN Bokningar b ON t.TjanstID = b.TjanstID
GROUP BY t.TjanstID, t.Namn;

-- Total intäkt per tjänst
SELECT 
    t.Namn AS Tjanst,
    COUNT(b.BokningID) AS Antal,
    SUM(t.Pris) AS TotalIntakt
FROM Bokningar b
JOIN Tjanster t ON b.TjanstID = t.TjanstID
GROUP BY t.TjanstID, t.Namn;

