CREATE DATABASE frisor_bokning;
USE frisor_bokning;

-- TABELLER

-- Kunder
CREATE TABLE Kunder (
    KundID INT AUTO_INCREMENT PRIMARY KEY,
    Namn VARCHAR(100) NOT NULL,
    Epost VARCHAR(100) NOT NULL UNIQUE
);

-- Tjänster
CREATE TABLE Tjanster (
    TjanstID INT AUTO_INCREMENT PRIMARY KEY,
    Namn VARCHAR(100) NOT NULL,
    Pris DECIMAL(10,2) NOT NULL CHECK (Pris >= 0)
);

-- Bokningar
CREATE TABLE Bokningar (
    BokningID INT AUTO_INCREMENT PRIMARY KEY,
    KundID INT NOT NULL,
    TjanstID INT NOT NULL,
    Datum DATETIME NOT NULL,
    
    CONSTRAINT fk_kund
        FOREIGN KEY (KundID) REFERENCES Kunder(KundID)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
        
    CONSTRAINT fk_tjanst
        FOREIGN KEY (TjanstID) REFERENCES Tjanster(TjanstID)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
        
    CONSTRAINT chk_datum
        CHECK (Datum >= '2025-01-01 08:00:00')
);

-- Loggtabell för bekräftelser
CREATE TABLE BekraftelseLogg (
    LoggID INT AUTO_INCREMENT PRIMARY KEY,
    BokningID INT NOT NULL,
    Meddelande VARCHAR(255) NOT NULL,
    SkapadTid DATETIME DEFAULT CURRENT_TIMESTAMP,
    
    CONSTRAINT fk_bokning_logg
        FOREIGN KEY (BokningID) REFERENCES Bokningar(BokningID)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

-- TRIGGER

DELIMITER //

CREATE TRIGGER trg_efter_bokning
AFTER INSERT ON Bokningar
FOR EACH ROW
BEGIN
    INSERT INTO BekraftelseLogg (BokningID, Meddelande)
    VALUES (
        NEW.BokningID,
        CONCAT('Bokning skapad för kund ID ', NEW.KundID,
               ' för tjänst ID ', NEW.TjanstID,
               ' den ', NEW.Datum)
    );
END //

DELIMITER ;


